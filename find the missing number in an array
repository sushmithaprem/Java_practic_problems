import java.util.*;
public class Learn{
	public static void main(String [] args) {
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int [] nums = new int[n];
		int sum = 0;
		for(int i=0; i<n; i++) {
			nums[i] = sc.nextInt();
			sum += nums[i];
		}
		int total = n * (n+1) / 2;
		System.out.println("Missing Number: " + (total - sum));
			

		
	}
}
